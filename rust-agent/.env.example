# Copy to .env and set your bot token from Discord Developer Portal → Bot → Reset Token
DISCORD_TOKEN=your-bot-token-here

# Tavily web search (research / self-improvement). Required for heartbeat-learn overnight runs. Get a key at tavily.com; ~1000 credits/month on free tier.
# TAVILY_API_KEY=your-tavily-api-key

# Optional: Discord user ID to receive a "Chump is online" DM when the bot connects. Enable Developer Mode in Discord, right-click your profile → Copy User ID.
# CHUMP_READY_DM_USER_ID=123456789012345678

# Optional: focus Chump on projects/repos (see docs/USER_STORIES.md)
# CHUMP_PROJECT_MODE=1

# Optional: start MLX servers on first Discord message instead of keeping them always on (see docs/CHUMP_SERVICE.md)
# CHUMP_WARM_SERVERS=1
# CHUMP_HOME=/path/to/rust-agent
# When using warm-the-ovens, start 7B on 8001 as well. Leave unset for 30B-only (saves ~4.5 GB RAM).
# WARM_PORT_2=8001

# Optional: enable delegate tool (summarize/extract). Worker uses 8000 when CHUMP_WORKER_API_BASE is unset (30B only).
# CHUMP_DELEGATE=1
# For a separate 7B worker, run serve-vllm-mlx-8001.sh and set:
# CHUMP_WORKER_API_BASE=http://localhost:8001/v1
